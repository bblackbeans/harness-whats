# Serviço Harness (LangGraph + Chatwoot)
PORT=8787
HARNESS_DATA_DIR=data
LOG_LEVEL=INFO

# Tenant ativo (modo 1 deploy = 1 cliente). Deixe vazio para rotear por inbox_id.
TENANT_ID=blackbeans
TENANTS_DIR=/app/tenants

# Ingress
INGRESS_MAX_RETRIES=3
INGRESS_RETRY_BASE_SECONDS=1.5

# Contexto (fallback global; cada tenant pode sobrescrever em tenant.json)
CONTEXT_SUMMARIZE_AFTER=12
CONTEXT_KEEP_RECENT=6

# Chatwoot (self-hosted)
CHATWOOT_BASE_URL=https://seu-chatwoot.com
CHATWOOT_BOT_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_WEBHOOK_SECRET=

# LangChain / OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Plataforma SaaS (PostgreSQL + Admin)
DATABASE_URL=postgresql+psycopg2://harness:harness@localhost:15432/harness
JWT_SECRET=change-me-in-production-use-long-random-string
ADMIN_EMAIL=admin@harness.local
ADMIN_PASSWORD=admin123
ADMIN_CORS_ORIGINS=http://localhost:3000
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Portal do cliente (usuário demo — opcional)
TENANT_PORTAL_EMAIL=cliente@blackbeans.local
TENANT_PORTAL_PASSWORD=cliente123
TENANT_PORTAL_TENANT_ID=blackbeans

# RAG (base de conhecimento por tenant)
RAG_ENABLED=true
RAG_TOP_K=5
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
